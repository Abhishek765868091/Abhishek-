class Queue:
    def __init__(self):
        self.queue=[]
    def is_empty(self):
        return len(self.queue)==0
    def enqueue (self,value):
        self.queue.append(value)
    def dequeue(self):
        if self.is_empty():
            return None
        self.queue.pop(0)
    def peek():
        if self.is_empty():
            return None
        self.queue(0)
q=Queue()
q.enqueue(2)
q.enqueue(4)
q.enqueue(6)
q.enqueue(8)
q.dequeue()
q.queue
